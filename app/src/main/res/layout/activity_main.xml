<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:padding="@dimen/spacing_med"
    android:background="@color/colorPrimaryDark">

    <!-- APP BAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="32dp"
        android:theme="@style/AppTheme.AppBarOverlay"
        android:background="@null">

        <!-- TOOLBAR -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/height_toolbar"
            app:buttonGravity="top"
            app:maxButtonHeight="56dp"
            android:paddingHorizontal="@dimen/spacing_small"
            app:menu="@menu/main"
            app:popupTheme="@style/AppTheme.NoActionBar"
            android:background="@null"
            app:titleTextColor="@color/shadowInvisible"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- VERTICAL SCROLL -->
    <ScrollView
        android:id="@+id/main_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/appbar"
        android:orientation="vertical">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/main_vertical_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/searchContainer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@drawable/bg_search_bar"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="4dp"
                    app:layout_constraintTop_toBottomOf="@+id/appBarLayout">

                    <EditText
                        android:id="@+id/etMainInput"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/paste_url"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:inputType="textUri"
                        android:maxLines="1" />

                    <ImageButton
                        android:id="@+id/btnClear"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/clear_button"
                        android:src="@drawable/ic_close"
                        android:visibility="invisible"
                        app:tint="@color/text_secondary"
                        tools:visibility="visible"/>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="@color/divider" />

                    <ImageButton
                        android:id="@+id/btnPaste"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_paste"
                        app:tint="@color/selector_paste_tint"
                        android:onClick="onPasteClick"/>
                </LinearLayout>

                <!-- PREVIEW CARD -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/preview_card"
                    android:layout_width="match_parent"
                    android:maxWidth="@dimen/size_preview_card"
                    android:layout_height="@dimen/size_preview_card"
                    app:layout_constraintTop_toBottomOf="@id/searchContainer"
                    android:layout_marginHorizontal="@dimen/spacing_med"
                    android:layout_marginVertical="@dimen/spacing_large"
                    app:cardCornerRadius="@dimen/corner_radius_primary"
                    app:cardElevation="@dimen/elevation_low"
                    app:cardBackgroundColor="@color/colorDarkerGray">

                    <!-- WEBVIEW -->
                    <WebView
                        android:id="@+id/preview_webview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:elevation="@dimen/elevation_middle"
                        android:contentDescription="@string/cont_desc_preview"
                        android:visibility="invisible"/>

                    <!-- THUMBNAIL -->
                    <ImageView
                        android:id="@+id/img_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:elevation="@dimen/elevation_middle"
                        android:contentDescription="@string/cont_desc_preview"
                        android:visibility="invisible" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/container_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:elevation="@dimen/elevation_middle"
                        android:contentDescription="@string/cont_desc_preview">

                        <!-- # OF TRACKS -->
                        <TextView
                            android:id="@+id/num_tracks_textview"
                            android:layout_width="wrap_content"
                            android:minWidth="@dimen/size_btn_primary"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            android:elevation="@dimen/elevation_mid_high"
                            android:layout_margin="@dimen/spacing_med"
                            android:paddingHorizontal="@dimen/spacing_med"
                            android:textAppearance="@style/TextAppMain"
                            android:textColor="@color/colorWhite"
                            android:textSize="@dimen/text_size_edittext"
                            android:background="@drawable/bg_rounded_sweep"
                            android:visibility="gone"/>

                        <!-- GLOW LOADER -->
                        <com.varunest.loader.TheGlowingLoader
                            android:id="@+id/glowing_loader"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="@dimen/spacing_xxxlarge"
                            android:elevation="@dimen/elevation_middle"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintRight_toRightOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:theglowingloader_line_1_color="@color/mvxPink"
                            app:theglowingloader_line_2_color="@color/colorWhite"
                            android:visibility="gone"/>

                        <!-- BUTTON PANEL -->
                        <LinearLayout android:name="@+id/button_panel"
                            android:layout_width="match_parent"
                            android:layout_height="72dp"
                            android:elevation="@dimen/elevation_high"
                            android:padding="@dimen/spacing_med"
                            android:gravity="end"
                            app:layout_constraintBottom_toBottomOf="@id/container_preview"
                            android:background="@drawable/bg_rounded_btm_shadow">

                            <!-- RESOLUTION SPINNER -->
                            <Spinner
                                android:id="@+id/res_spinner"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_marginVertical="6dp"
                                android:background="@drawable/bg_rounded_sweep_inverse" />

                            <!-- FILENAME EDITOR -->
                            <EditText
                                android:id="@+id/filename_edittext"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="match_parent"
                                android:layout_marginVertical="6dp"
                                android:elevation="@dimen/elevation_mid_high"
                                android:layout_marginHorizontal="16dp"
                                android:padding="@dimen/spacing_small"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent"
                                android:importantForAutofill="no"
                                android:inputType="text"
                                android:textColorHint="@color/shadowInverseLight"
                                android:textAppearance="@style/TextAppMain"
                                android:textSize="16sp"
                                android:textColor="@color/shadowInverseDark"
                                android:background="@drawable/bg_rounded_sweep"
                                android:visibility="visible"
                                android:enabled="false" />

                            <!-- DOWNLOAD PROGRESS -->
                            <com.daimajia.numberprogressbar.NumberProgressBar
                                android:id="@+id/num_progress"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="match_parent"
                                android:layout_margin="@dimen/spacing_small"
                                app:progress_current="0"
                                app:progress_max="100"
                                app:progress_text_size="14sp"
                                app:progress_reached_bar_height="1.5dp"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:progress_reached_color="@color/colorAccent"
                                app:progress_text_color="@color/white"
                                app:progress_unreached_color="@color/shadowInverse"
                                android:visibility="gone"/>

                            <!-- BUTTON HOLDER -->
                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent">

                                <!-- DOWNLOAD BTN -->
                                <ImageButton
                                    android:id="@+id/btn_download"
                                    android:layout_width="@dimen/size_btn_primary"
                                    android:layout_height="@dimen/size_btn_primary"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    android:contentDescription="@string/cont_desc_download_btn"
                                    android:layout_margin="@dimen/spacing_small"
                                    android:elevation="@dimen/elevation_top"
                                    android:background="@drawable/ic_download_24"
                                    android:visibility="gone"
                                    android:onClick="onDownloadClick"/>

                                <!-- ANIMATED CIRCLE -->
                                <ImageView
                                    android:id="@+id/iv_circle"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    android:elevation="@dimen/elevation_mid_high"
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:layout_marginEnd="@dimen/spacing_small"
                                    android:scaleType="center"
                                    android:src="@drawable/avd_circle"
                                    android:visibility="gone"
                                    android:contentDescription="@string/cont_desc_download_btn"/>

                            </androidx.constraintlayout.widget.ConstraintLayout>

                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.cardview.widget.CardView>

                <!-- AD BANNER -->
                <FrameLayout
                    android:id="@+id/banner_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/preview_card"
                    android:visibility="invisible">

                    <com.google.android.gms.ads.AdView
                        android:id="@+id/banner_adview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                </FrameLayout>

                <!-- FILE / HINT HOLDER -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/file_hint_holder"
                    android:elevation="@dimen/elevation_top"
                    android:layout_margin="@dimen/spacing_med"
                    android:background="@drawable/bg_rounded_black_stroke_inv"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/preview_card"
                    android:visibility="gone"/>

                <!-- PERMISSION HOLDER -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/permission_holder"
                    android:elevation="@dimen/elevation_top"
                    android:paddingVertical="8dp"
                    android:layout_marginHorizontal="@dimen/spacing_med"
                    android:layout_margin="@dimen/spacing_med"
                    android:background="@drawable/bg_rounded_black_stroke_inv"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/preview_card"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:text="Run in background:"
                        android:textColor="@color/shadowInverseDark"
                        android:textSize="16sp"
                        android:layout_marginVertical="8dp"
                        android:layout_marginStart="16dp"/>

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:background="@color/shadowInverseDark"
                        android:text="Enable"
                        android:textColor="@color/shadowDarker"
                        android:layout_margin="8dp"
                        android:onClick="onEnableBackgroundClicked"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </LinearLayout>

            <!-- BIG FRAG -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/big_frag_holder"
                android:elevation="@dimen/elevation_mid_high"
                android:background="@drawable/bg_rounded_black_stroke_inv"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:paddingBottom="16dp"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>